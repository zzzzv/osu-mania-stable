{
  "name": "osu-mania-stable",
  "version": "5.0.1",
  "description": "osu!stable version of osu!mania ruleset based on osu!lazer source code.",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    "import": {
      "default": "./lib/index.mjs",
      "types": "./lib/index.d.ts"
    },
    "require": {
      "default": "./lib/index.cjs",
      "types": "./lib/index.d.ts"
    }
  },
  "types": "./lib/index.d.ts",
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "test": "jest --verbose",
    "fix": "eslint --fix ./src",
    "format": "eslint --fix ./lib/** --no-ignore",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "docs": "npx typedoc src/index.ts"
  },
  "keywords": [
    "osu",
    "osu!lazer",
    "osu!mania"
  ],
  "author": "Kionell",
  "repository": {
    "type": "git",
    "url": "https://github.com/kionell/osu-mania-stable"
  },
  "license": "MIT",
  "dependencies": {
    "osu-classes": "github:zzzzv/osu-classes"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-esm-transformer": "^1.0.0",
    "osu-parsers": "github:zzzzv/osu-parsers",
    "rollup": "^4.61.1",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-node-externals": "^9.0.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "osu-classes",
      "unrs-resolver"
    ]
  }
}
